{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Format with CSharpier",
      "type": "shell",
      "command": "csharpier",
      "args": ["format", "${file}"],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Format All C# Files",
      "type": "shell",
      "command": "csharpier",
      "args": ["format", "Assets"],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
